<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <!-- ═══════════════════════════════════════════
         LOCK SCREEN
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lockScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_black">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/green_primary"
            android:textSize="56sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mon 01 jan 2026"
            android:textColor="@color/green_primary"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="root@android:~$ _"
            android:textColor="@color/green_primary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginTop="48dp" />

        <TextView
            android:id="@+id/tvSlideUnlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/slide_to_unlock"
            android:textColor="@color/green_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="96dp"
            android:alpha="0.45" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         HOME SCREEN
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_black"
        android:visibility="gone">

        <!-- Scrollable area: title + stats + app grid -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/green_primary"
                    android:textSize="24sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />

                <!-- Stats card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_status_card"
                    android:padding="16dp"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[ system ]"
                        android:textColor="@color/green_primary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:alpha="0.6"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="loading..."
                        android:textColor="@color/green_primary"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

                <!-- Apps section header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ apps ]"
                    android:textColor="@color/green_primary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:alpha="0.6"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />

                <!-- App grid — isNestedScrollingEnabled=false set in code -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvApps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- Dock — 4 equal slots, pinned at bottom -->
        <LinearLayout
            android:id="@+id/dock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_dock"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Slot 0 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/dockSlot0">

                <ImageView
                    android:id="@+id/dockIcon0"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_app_icon"
                    android:padding="5dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/dockName0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/green_primary"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Slot 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/dockSlot1">

                <ImageView
                    android:id="@+id/dockIcon1"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_app_icon"
                    android:padding="5dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/dockName1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/green_primary"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Slot 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/dockSlot2">

                <ImageView
                    android:id="@+id/dockIcon2"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_app_icon"
                    android:padding="5dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/dockName2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/green_primary"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Slot 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:id="@+id/dockSlot3">

                <ImageView
                    android:id="@+id/dockIcon3"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_app_icon"
                    android:padding="5dp"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/dockName3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/green_primary"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
