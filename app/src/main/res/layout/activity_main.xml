<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_black">

    <!-- ═══════════════════════════════════════════
         LOCK SCREEN
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lockScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_black">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/green_primary"
            android:textSize="56sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mon 01 jan 2026"
            android:textColor="@color/green_primary"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="root@android:~$ _"
            android:textColor="@color/green_primary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginTop="48dp" />

        <TextView
            android:id="@+id/tvSlideUnlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/slide_to_unlock"
            android:textColor="@color/green_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="96dp"
            android:alpha="0.45" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         HOME SCREEN
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/bg_black"
        android:visibility="gone">

        <!-- App title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/green_primary"
            android:textSize="28sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <!-- System stats card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_status_card"
            android:padding="16dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ system ]"
                android:textColor="@color/green_primary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:alpha="0.6"
                android:layout_marginBottom="10dp" />

            <!-- Populated every 3s by StatsProvider via onStats() callback -->
            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="loading..."
                android:textColor="@color/green_primary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
